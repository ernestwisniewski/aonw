SERVERPOD_RUN_MODE=development
SERVERPOD_SERVER_ID=local
SERVERPOD_LOGGING_MODE=normal
SERVERPOD_SERVER_ROLE=monolith
SERVERPOD_APPLY_MIGRATIONS=true

SERVERPOD_DATABASE_HOST=localhost
SERVERPOD_DATABASE_PORT=5432
SERVERPOD_DATABASE_NAME=aonw
SERVERPOD_DATABASE_USER=aonw
SERVERPOD_DATABASE_PASSWORD=replace-with-local-postgres-password
SERVERPOD_SERVICE_SECRET=replace-with-long-random-secret
SERVERPOD_REDIS_ENABLED=true
SERVERPOD_REDIS_HOST=localhost
SERVERPOD_REDIS_PORT=6379
SERVERPOD_PASSWORD_redis=replace-with-local-redis-password

SERVERPOD_API_SERVER_PORT=8080
SERVERPOD_INSIGHTS_SERVER_PORT=8081
SERVERPOD_WEB_SERVER_PORT=8082
SERVERPOD_WEBSOCKET_PING_INTERVAL=20

SERVERPOD_PASSWORD_emailSecretHashPepper=replace-with-long-random-secret
SERVERPOD_PASSWORD_jwtHmacSha512PrivateKey=replace-with-long-random-secret
SERVERPOD_PASSWORD_jwtRefreshTokenHashPepper=replace-with-long-random-secret

# Optional social sign-in. Leave any value empty to disable that provider.
# Multi-line values are supplied base64-encoded and decoded by the Docker
# entrypoint when running through compose.
AONW_GOOGLE_CLIENT_SECRET_B64=
AONW_APPLE_KEY_B64=
SERVERPOD_PASSWORD_appleServiceIdentifier=
SERVERPOD_PASSWORD_appleBundleIdentifier=
SERVERPOD_PASSWORD_appleRedirectUri=
SERVERPOD_PASSWORD_appleTeamId=
SERVERPOD_PASSWORD_appleKeyId=
SERVERPOD_PASSWORD_appleAndroidPackageIdentifier=
SERVERPOD_PASSWORD_appleWebRedirectUri=
