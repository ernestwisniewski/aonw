AONW_SERVER_IMAGE=aonw-server:local

# Optional override. Makefile-driven server builds use pubspec.yaml when this
# is empty; direct docker compose builds should set it explicitly.
AONW_APP_VERSION=
AONW_RELEASE_CHANNEL=ALPHA

POSTGRES_DB=aonw
POSTGRES_USER=aonw
POSTGRES_PASSWORD=replace-with-local-postgres-password
AONW_POSTGRES_BIND=127.0.0.1
AONW_POSTGRES_PORT=5432

SERVERPOD_RUN_MODE=staging
SERVERPOD_SERVER_ID=default
SERVERPOD_LOGGING_MODE=normal
SERVERPOD_SERVER_ROLE=monolith
SERVERPOD_APPLY_MIGRATIONS=true

SERVERPOD_DATABASE_HOST=postgres
SERVERPOD_DATABASE_PORT=5432
SERVERPOD_DATABASE_NAME=aonw
SERVERPOD_DATABASE_USER=aonw
SERVERPOD_DATABASE_PASSWORD=replace-with-local-postgres-password
SERVERPOD_SERVICE_SECRET=replace-with-long-random-secret
SERVERPOD_REDIS_ENABLED=true
SERVERPOD_REDIS_HOST=redis
SERVERPOD_REDIS_PORT=6379
SERVERPOD_PASSWORD_redis=replace-with-redis-password

SERVERPOD_API_SERVER_PORT=8080
SERVERPOD_API_SERVER_PUBLIC_HOST=api.aonw.net
SERVERPOD_API_SERVER_PUBLIC_PORT=443
SERVERPOD_API_SERVER_PUBLIC_SCHEME=https
SERVERPOD_INSIGHTS_SERVER_PORT=8081
SERVERPOD_INSIGHTS_SERVER_PUBLIC_HOST=insights.aonw.net
SERVERPOD_INSIGHTS_SERVER_PUBLIC_PORT=443
SERVERPOD_INSIGHTS_SERVER_PUBLIC_SCHEME=https
SERVERPOD_WEB_SERVER_PORT=8082
SERVERPOD_WEB_SERVER_PUBLIC_HOST=api.aonw.net
SERVERPOD_WEB_SERVER_PUBLIC_PORT=443
SERVERPOD_WEB_SERVER_PUBLIC_SCHEME=https
SERVERPOD_WEBSOCKET_PING_INTERVAL=20

# Serverpod Auth IDP password aliases.
SERVERPOD_PASSWORD_emailSecretHashPepper=replace-with-long-random-secret
SERVERPOD_PASSWORD_jwtHmacSha512PrivateKey=replace-with-long-random-secret
SERVERPOD_PASSWORD_jwtRefreshTokenHashPepper=replace-with-long-random-secret

# Optional social sign-in. Leave any value empty to disable that provider; the
# server enables Google/Apple only when their secrets are present.
#
# The Google client JSON and the Apple sign-in PEM key are multi-line, which a
# .env file cannot hold, so they are stored base64-encoded on a single line and
# decoded by server/docker-entrypoint.sh. Generate them with:
#   base64 -w0 google_client_secret.json   # Linux
#   base64 -i  AuthKey_XXXX.p8              # macOS
AONW_GOOGLE_CLIENT_SECRET_B64=
AONW_APPLE_KEY_B64=
SERVERPOD_PASSWORD_appleServiceIdentifier=
SERVERPOD_PASSWORD_appleBundleIdentifier=
SERVERPOD_PASSWORD_appleRedirectUri=
SERVERPOD_PASSWORD_appleTeamId=
SERVERPOD_PASSWORD_appleKeyId=
SERVERPOD_PASSWORD_appleAndroidPackageIdentifier=
SERVERPOD_PASSWORD_appleWebRedirectUri=

AONW_SERVER_BIND=127.0.0.1
AONW_SERVER_PUBLIC_PORT=8080
AONW_INSIGHTS_BIND=127.0.0.1
AONW_INSIGHTS_PUBLIC_PORT=8081

# Public host names served by Caddy. Update these to your domains.
AONW_API_HOST=api.aonw.net
AONW_INSIGHTS_HOST=insights.aonw.net
AONW_HOMEPAGE_HOST=aonw.net
AONW_DEMO_HOST=demo.aonw.net
AONW_UPSTREAM=server:8080
AONW_WEB_UPSTREAM=server:8082
AONW_INSIGHTS_UPSTREAM=server:8081

# Build-time API URL baked into the Flutter web bundle.
AONW_API_BASE_URL=https://api.aonw.net

AONW_HTTP_PORT=80
AONW_HTTPS_PORT=443
